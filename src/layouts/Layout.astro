---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	canonical?: string;
	image?: string;
	type?: 'website' | 'article';
	jsonLd?: Record<string, unknown>;
}

const {
	title,
	description = 'Bản dịch tiếng Việt của các bản tin công nghệ hàng tuần, tập trung vào AI, lập trình, sản phẩm và xu hướng tương lai.',
	canonical,
	image,
	type = 'website',
	jsonLd,
} = Astro.props;
const pageTitle = `${title} | Weekly`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = image ? new URL(image, Astro.site).toString() : undefined;
const googleAnalyticsId = 'G-17ESC9MW85';
---

<!doctype html>
<html lang="vi" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="referrer" content="no-referrer-when-downgrade" />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content="Weekly" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content="vi_VN" />
		{imageUrl && <meta property="og:image" content={imageUrl} />}
		<meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{imageUrl && <meta name="twitter:image" content={imageUrl} />}
		{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
		{googleAnalyticsId && (
			<script define:vars={{ googleAnalyticsId }}>
				window.dataLayer = window.dataLayer || [];
				function gtag() { window.dataLayer.push(arguments); }

				const loadAnalytics = () => {
					if (document.querySelector(`script[src*="${googleAnalyticsId}"]`)) return;

					const script = document.createElement('script');
					script.async = true;
					script.src = `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`;
					document.head.append(script);

					gtag('js', new Date());
					gtag('config', googleAnalyticsId);
				};

				if ('requestIdleCallback' in window) {
					requestIdleCallback(loadAnalytics, { timeout: 3000 });
				} else {
					window.addEventListener('load', () => setTimeout(loadAnalytics, 1500), { once: true });
				}
			</script>
		)}
		<title>{pageTitle}</title>
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'dark'; // Default to dark as per sketch
			})();
		
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body class="min-h-screen flex flex-col font-sans selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black antialiased">
		<header class="border-b border-black/5 dark:border-white/5 sticky top-0 z-50 bg-white/80 dark:bg-[#0c0c0c]/80 backdrop-blur-md transition-colors duration-300">
			<nav class="flex flex-row items-start md:items-center justify-between px-4 sm:px-6 py-6 sm:py-8 max-w-5xl mx-auto w-full gap-4">
				<div class="flex flex-col">
					<a href="/" class="text-2xl font-semibold tracking-tight text-black dark:text-white hover:opacity-80 transition-opacity">Weekly</a>
					<p class="text-[10px] text-gray-500 uppercase tracking-[0.2em] font-bold mt-1">Technology & Future Trends</p>
				</div>
				<div class="flex items-center space-x-4 md:space-x-6 text-sm font-medium text-gray-500 dark:text-gray-400 pt-3 md:pt-0">
					<div class="relative group hidden md:block">
						<div class="absolute -bottom-1.5 left-0 w-full h-[2px] bg-black dark:bg-white rounded-full"></div>
					</div>
					<button id="issue-search-trigger" class="group flex items-center gap-2 rounded-full border border-black/10 dark:border-white/10 bg-black/[0.02] dark:bg-white/[0.04] px-3 py-1.5 text-xs text-black dark:text-white hover:border-black/20 dark:hover:border-white/20 hover:bg-black/[0.04] dark:hover:bg-white/[0.08] transition-all cursor-pointer" aria-label="Search issues" type="button">
						<span>Search</span>
						<kbd class="hidden sm:inline-flex items-center rounded-md bg-black/5 dark:bg-white/10 px-1.5 py-0.5 text-[10px] font-semibold text-gray-500 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white">⌘K</kbd>
					</button>
					<button id="theme-toggle" class="text-black dark:text-white hover:opacity-70 cursor-pointer ml-2 transition-all" aria-label="Toggle theme">
						<svg class="sun hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
						<svg class="moon block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
					</button>
					<script is:inline>
						document.getElementById("theme-toggle").addEventListener("click", () => {
							const element = document.documentElement;
							element.classList.toggle("dark");
							const isDark = element.classList.contains("dark");
							localStorage.setItem("theme", isDark ? "dark" : "light");
						});
					</script>
				</div>
			</nav>
		</header>

		<main class="flex-1 w-full max-w-5xl mx-auto px-4 sm:px-6 pt-10 sm:pt-16 pb-20 sm:pb-24">
			<slot />
		</main>

		<div id="issue-search-overlay" class="fixed inset-0 z-[100] hidden items-start justify-center bg-black/50 px-4 pt-20 backdrop-blur-sm sm:pt-28" role="dialog" aria-modal="true" aria-labelledby="issue-search-label">
			<div id="issue-search-panel" class="w-full max-w-2xl overflow-hidden rounded-3xl border border-black/10 dark:border-white/10 bg-white shadow-2xl dark:bg-[#111]">
				<div class="flex items-center gap-3 border-b border-black/5 dark:border-white/10 px-4 py-4 sm:px-5">
					<svg class="h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
					<label id="issue-search-label" for="issue-search-input" class="sr-only">Search issues</label>
					<input id="issue-search-input" class="min-w-0 flex-1 bg-transparent text-base text-black outline-none placeholder:text-gray-400 dark:text-white sm:text-lg" type="search" placeholder="Tìm số Weekly..." autocomplete="off" />
					<kbd class="hidden rounded-md bg-black/5 px-2 py-1 text-[10px] font-bold uppercase tracking-widest text-gray-500 dark:bg-white/10 dark:text-gray-400 sm:block">Esc</kbd>
				</div>
				<div id="issue-search-results" class="max-h-[60vh] overflow-y-auto p-2 sm:p-3"></div>
			</div>
		</div>

		<div id="page-loading-overlay" class="pointer-events-none fixed inset-0 z-[120] hidden overflow-y-auto bg-white dark:bg-[#0c0c0c]" aria-hidden="true">
			<div class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 sm:py-16">
				<div class="mb-10 h-3 w-24 animate-pulse rounded-full bg-black/10 dark:bg-white/10"></div>
				<div class="mx-auto max-w-3xl">
					<div class="mb-5 h-4 w-28 animate-pulse rounded-full bg-black/10 dark:bg-white/10"></div>
					<div class="mb-4 h-10 w-5/6 animate-pulse rounded-2xl bg-black/10 dark:bg-white/10 sm:h-12"></div>
					<div class="mb-10 h-10 w-2/3 animate-pulse rounded-2xl bg-black/10 dark:bg-white/10 sm:h-12"></div>
					<div class="space-y-4">
						<div class="h-5 w-full animate-pulse rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="h-5 w-11/12 animate-pulse rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="h-5 w-10/12 animate-pulse rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="h-5 w-full animate-pulse rounded-full bg-black/10 dark:bg-white/10"></div>
						<div class="h-5 w-8/12 animate-pulse rounded-full bg-black/10 dark:bg-white/10"></div>
					</div>
					<div class="mt-12 grid gap-4 sm:grid-cols-2">
						<div class="h-32 animate-pulse rounded-3xl bg-black/10 dark:bg-white/10"></div>
						<div class="h-32 animate-pulse rounded-3xl bg-black/10 dark:bg-white/10"></div>
					</div>
				</div>
			</div>
		</div>

		<footer class="max-w-5xl mx-auto w-full px-4 sm:px-6 py-12 mt-auto border-t border-black/5 dark:border-white/5 transition-colors duration-300">
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-[11px] text-gray-500 uppercase tracking-widest font-semibold">
				<div class="opacity-60 text-center sm:text-left leading-relaxed">
					© {new Date().getFullYear()} Weekly.
					Original by <a href="https://github.com/ruanyf/weekly" target="_blank" class="underline decoration-black/20 dark:decoration-white/20 underline-offset-4 hover:decoration-black dark:hover:decoration-white transition-all text-black dark:text-white">Ruan Yifeng</a>.
					Translated by <a href="https://github.com/lmquang" target="_blank" class="underline decoration-black/20 dark:decoration-white/20 underline-offset-4 hover:decoration-black dark:hover:decoration-white transition-all text-black dark:text-white">Quang</a>.
				</div>
			</div>
		</footer>

		<script>
			const searchTrigger = document.getElementById('issue-search-trigger');
			const searchOverlay = document.getElementById('issue-search-overlay');
			const searchPanel = document.getElementById('issue-search-panel');
			const searchInput = document.getElementById('issue-search-input');
			const searchResults = document.getElementById('issue-search-results');
			const pageLoadingOverlay = document.getElementById('page-loading-overlay');
			let searchIssues = [];
			let searchIndexPromise;
			let currentResults = [];

			const showPageLoading = () => {
				pageLoadingOverlay?.classList.remove('hidden');
				pageLoadingOverlay?.classList.add('flex');
			};

			const navigateWithLoading = (url) => {
				showPageLoading();
				requestAnimationFrame(() => {
					setTimeout(() => {
						window.location.href = url;
					}, 80);
				});
			};

			const handleIssueNavigation = (event) => {
				if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

				const link = event.target instanceof Element ? event.target.closest('a[href]') : null;
				if (!link) return;

				const url = new URL(link.href, window.location.href);
				if (link.target || url.origin !== window.location.origin || !url.pathname.startsWith('/issues/') || url.href === window.location.href) return;

				event.preventDefault();
				navigateWithLoading(url.href);
			};

			const createResult = (issue, index) => {
				const link = document.createElement('a');
				link.href = issue.url;
				link.className = `block rounded-2xl px-4 py-3 transition-colors hover:bg-black/[0.04] dark:hover:bg-white/[0.06] ${index === 0 ? 'bg-black/[0.03] dark:bg-white/[0.05]' : ''}`;

				const meta = document.createElement('p');
				meta.className = 'mb-1 text-[10px] font-bold uppercase tracking-widest text-gray-500';
				meta.textContent = `Issue #${issue.number}`;

				const title = document.createElement('p');
				title.className = 'text-base font-medium leading-snug text-black dark:text-white';
				title.textContent = issue.title;

				const summary = document.createElement('p');
				summary.className = 'mt-1 line-clamp-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400';
				summary.textContent = issue.summary;

				link.append(meta, title, summary);

				if (issue.tags.length > 0) {
					const tags = document.createElement('div');
					tags.className = 'mt-3 flex flex-wrap gap-1.5';

					issue.tags.slice(0, 4).forEach((tag) => {
						const badge = document.createElement('span');
						badge.className = 'rounded-full bg-black/5 px-2 py-0.5 text-[10px] font-semibold text-gray-500 dark:bg-white/10 dark:text-gray-400';
						badge.textContent = tag;
						tags.append(badge);
					});

					link.append(tags);
				}

				return link;
			};

			const renderResults = () => {
				if (!searchResults) return;
				searchResults.replaceChildren();

				if (searchIssues.length === 0) {
					const skeletons = Array.from({ length: 4 }, () => {
						const item = document.createElement('div');
						item.className = 'rounded-2xl px-4 py-3';

						const meta = document.createElement('div');
						meta.className = 'mb-3 h-3 w-20 animate-pulse rounded-full bg-black/10 dark:bg-white/10';

						const title = document.createElement('div');
						title.className = 'mb-3 h-5 w-4/5 animate-pulse rounded-full bg-black/10 dark:bg-white/10';

						const summary = document.createElement('div');
						summary.className = 'h-4 w-11/12 animate-pulse rounded-full bg-black/10 dark:bg-white/10';

						item.append(meta, title, summary);
						return item;
					});

					searchResults.append(...skeletons);
					return;
				}

				if (currentResults.length === 0) {
					const emptyState = document.createElement('p');
					emptyState.className = 'px-4 py-10 text-center text-sm text-gray-500';
					emptyState.textContent = 'Không tìm thấy nội dung phù hợp';
					searchResults.append(emptyState);
					return;
				}

				searchResults.append(...currentResults.map(createResult));
			};

			const normalizeSearchText = (value) =>
				value
					.toLowerCase()
					.normalize('NFD')
					.replace(/[\u0300-\u036f]/g, '')
					.replace(/đ/g, 'd');

			const getSearchScore = (issue, query) => {
				if (!query) return 1;

				const number = normalizeSearchText(issue.number);
				const title = normalizeSearchText(issue.title);
				const tags = normalizeSearchText(issue.tags.join(' '));
				const summary = normalizeSearchText(issue.summary);

				if (number === query || `issue ${number}` === query) return 100;
				if (tags.split(/\s+/).includes(query)) return 90;
				if (tags.includes(query)) return 85;
				if (title.includes(query)) return 80;
				if (summary.includes(query)) return 50;

				const queryWords = query.split(/\s+/).filter(Boolean);
				if (queryWords.length > 1 && queryWords.every((word) => `${title} ${tags} ${summary}`.includes(word))) return 10;

				return 0;
			};

			const filterResults = () => {
				const query = normalizeSearchText(searchInput?.value.trim() ?? '');
				currentResults = searchIssues
					.map((issue) => ({ issue, score: getSearchScore(issue, query) }))
					.filter((result) => result.score > 0)
					.sort((a, b) => b.score - a.score || Number(b.issue.number) - Number(a.issue.number))
					.slice(0, 8)
					.map((result) => result.issue);
				renderResults();
			};

			const loadSearchIndex = async () => {
				if (searchIssues.length > 0) return searchIssues;
				searchIndexPromise ??= fetch('/search-index.json')
					.then((response) => {
						if (!response.ok) throw new Error('Failed to load search index');
						return response.json();
					})
					.then((issues) => {
						searchIssues = issues;
						currentResults = searchIssues.slice(0, 8);
						return searchIssues;
					});

				return searchIndexPromise;
			};

			const openSearch = async () => {
				if (!searchOverlay || !searchInput) return;
				searchOverlay.classList.remove('hidden');
				searchOverlay.classList.add('flex');
				document.body.style.overflow = 'hidden';
				requestAnimationFrame(() => searchInput.focus());
				renderResults();

				try {
					await loadSearchIndex();
					filterResults();
				} catch {
					if (!searchResults) return;
					const errorState = document.createElement('p');
					errorState.className = 'px-4 py-10 text-center text-sm text-gray-500';
					errorState.textContent = 'Không tải được dữ liệu tìm kiếm';
					searchResults.replaceChildren(errorState);
				}
			};

			const closeSearch = () => {
				if (!searchOverlay || !searchInput) return;
				searchOverlay.classList.add('hidden');
				searchOverlay.classList.remove('flex');
				document.body.style.overflow = '';
				searchInput.value = '';
			};

			searchTrigger?.addEventListener('click', openSearch);
			searchInput?.addEventListener('input', filterResults);
			searchInput?.addEventListener('keydown', (event) => {
				if (event.key === 'Enter' && currentResults[0]) {
					navigateWithLoading(currentResults[0].url);
				}
			});

			searchOverlay?.addEventListener('click', closeSearch);
			searchPanel?.addEventListener('click', (event) => event.stopPropagation());

			document.addEventListener('keydown', (event) => {
				const isSearchShortcut = event.key.toLowerCase() === 'k' && (event.metaKey || event.ctrlKey);

				if (isSearchShortcut) {
					event.preventDefault();
					openSearch();
				}

				if (event.key === 'Escape') {
					closeSearch();
				}
			});

			document.addEventListener('click', handleIssueNavigation, true);
		</script>
	</body>
</html>
