<div id="issue-search-overlay" class="fixed inset-0 z-[100] hidden items-start justify-center bg-black/50 px-4 pt-20 backdrop-blur-sm sm:pt-28" role="dialog" aria-modal="true" aria-labelledby="issue-search-label">
	<div id="issue-search-panel" class="w-full max-w-2xl overflow-hidden rounded-3xl border border-black/10 dark:border-white/10 bg-white shadow-2xl dark:bg-[#111]">
		<div class="flex items-center gap-3 border-b border-black/5 dark:border-white/10 px-4 py-4 sm:px-5">
			<svg class="h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
			<label id="issue-search-label" for="issue-search-input" class="sr-only">Search issues</label>
			<input id="issue-search-input" class="min-w-0 flex-1 bg-transparent text-base text-black outline-none placeholder:text-gray-400 dark:text-white sm:text-lg" type="search" placeholder="Tìm số Weekly..." autocomplete="off" />
			<kbd class="hidden rounded-md bg-black/5 px-2 py-1 text-[10px] font-bold uppercase tracking-widest text-gray-500 dark:bg-white/10 dark:text-gray-400 sm:block">Esc</kbd>
		</div>
		<div id="issue-search-results" class="max-h-[60vh] overflow-y-auto p-2 sm:p-3"></div>
	</div>
</div>

<script>
	const searchTrigger = document.getElementById('issue-search-trigger');
	const searchOverlay = document.getElementById('issue-search-overlay');
	const searchPanel = document.getElementById('issue-search-panel');
	const searchInput = document.getElementById('issue-search-input');
	const searchResults = document.getElementById('issue-search-results');
	let searchIssues = [];
	let searchIndexPromise;
	let currentResults = [];

	const createResult = (issue, index) => {
		const link = document.createElement('a');
		link.href = issue.url;
		link.className = `block rounded-2xl px-4 py-3 transition-colors hover:bg-black/[0.04] dark:hover:bg-white/[0.06] ${index === 0 ? 'bg-black/[0.03] dark:bg-white/[0.05]' : ''}`;

		const meta = document.createElement('p');
		meta.className = 'mb-1 text-[10px] font-bold uppercase tracking-widest text-gray-500';
		meta.textContent = `Issue #${issue.number}`;

		const title = document.createElement('p');
		title.className = 'text-base font-medium leading-snug text-black dark:text-white';
		title.textContent = issue.title;

		const summary = document.createElement('p');
		summary.className = 'mt-1 line-clamp-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400';
		summary.textContent = issue.summary;

		link.append(meta, title, summary);

		if (issue.tags.length > 0) {
			const tags = document.createElement('div');
			tags.className = 'mt-3 flex flex-wrap gap-1.5';

			issue.tags.slice(0, 4).forEach((tag) => {
				const badge = document.createElement('span');
				badge.className = 'rounded-full bg-black/5 px-2 py-0.5 text-[10px] font-semibold text-gray-500 dark:bg-white/10 dark:text-gray-400';
				badge.textContent = tag;
				tags.append(badge);
			});

			link.append(tags);
		}

		return link;
	};

	const renderResults = () => {
		if (!searchResults) return;
		searchResults.replaceChildren();

		if (searchIssues.length === 0) {
			const skeletons = Array.from({ length: 4 }, () => {
				const item = document.createElement('div');
				item.className = 'rounded-2xl px-4 py-3';

				const meta = document.createElement('div');
				meta.className = 'mb-3 h-3 w-20 animate-pulse rounded-full bg-black/10 dark:bg-white/10';

				const title = document.createElement('div');
				title.className = 'mb-3 h-5 w-4/5 animate-pulse rounded-full bg-black/10 dark:bg-white/10';

				const summary = document.createElement('div');
				summary.className = 'h-4 w-11/12 animate-pulse rounded-full bg-black/10 dark:bg-white/10';

				item.append(meta, title, summary);
				return item;
			});

			searchResults.append(...skeletons);
			return;
		}

		if (currentResults.length === 0) {
			const emptyState = document.createElement('p');
			emptyState.className = 'px-4 py-10 text-center text-sm text-gray-500';
			emptyState.textContent = 'Không tìm thấy nội dung phù hợp';
			searchResults.append(emptyState);
			return;
		}

		searchResults.append(...currentResults.map(createResult));
	};

	const normalizeSearchText = (value) =>
		value
			.toLowerCase()
			.normalize('NFD')
			.replace(/[\u0300-\u036f]/g, '')
			.replace(/đ/g, 'd');

	const getSearchScore = (issue, query) => {
		if (!query) return 1;

		const number = normalizeSearchText(issue.number);
		const title = normalizeSearchText(issue.title);
		const tags = normalizeSearchText(issue.tags.join(' '));
		const summary = normalizeSearchText(issue.summary);

		if (number === query || `issue ${number}` === query) return 100;
		if (tags.split(/\s+/).includes(query)) return 90;
		if (tags.includes(query)) return 85;
		if (title.includes(query)) return 80;
		if (summary.includes(query)) return 50;

		const queryWords = query.split(/\s+/).filter(Boolean);
		if (queryWords.length > 1 && queryWords.every((word) => `${title} ${tags} ${summary}`.includes(word))) return 10;

		return 0;
	};

	const filterResults = () => {
		const query = normalizeSearchText(searchInput?.value.trim() ?? '');
		currentResults = searchIssues
			.map((issue) => ({ issue, score: getSearchScore(issue, query) }))
			.filter((result) => result.score > 0)
			.sort((a, b) => b.score - a.score || Number(b.issue.number) - Number(a.issue.number))
			.slice(0, 8)
			.map((result) => result.issue);
		renderResults();
	};

	const loadSearchIndex = async () => {
		if (searchIssues.length > 0) return searchIssues;
		searchIndexPromise ??= fetch('/search-index.json')
			.then((response) => {
				if (!response.ok) throw new Error('Failed to load search index');
				return response.json();
			})
			.then((issues) => {
				searchIssues = issues;
				currentResults = searchIssues.slice(0, 8);
				return searchIssues;
			});

		return searchIndexPromise;
	};

	const openSearch = async () => {
		if (!searchOverlay || !searchInput) return;
		searchOverlay.classList.remove('hidden');
		searchOverlay.classList.add('flex');
		document.body.style.overflow = 'hidden';
		requestAnimationFrame(() => searchInput.focus());
		renderResults();

		try {
			await loadSearchIndex();
			filterResults();
		} catch {
			if (!searchResults) return;
			const errorState = document.createElement('p');
			errorState.className = 'px-4 py-10 text-center text-sm text-gray-500';
			errorState.textContent = 'Không tải được dữ liệu tìm kiếm';
			searchResults.replaceChildren(errorState);
		}
	};

	const closeSearch = () => {
		if (!searchOverlay || !searchInput) return;
		searchOverlay.classList.add('hidden');
		searchOverlay.classList.remove('flex');
		document.body.style.overflow = '';
		searchInput.value = '';
	};

	searchTrigger?.addEventListener('click', openSearch);
	searchInput?.addEventListener('input', filterResults);
	searchInput?.addEventListener('keydown', (event) => {
		if (event.key === 'Enter' && currentResults[0]) {
			window.location.href = currentResults[0].url;
		}
	});

	searchOverlay?.addEventListener('click', closeSearch);
	searchPanel?.addEventListener('click', (event) => event.stopPropagation());

	document.addEventListener('keydown', (event) => {
		const isSearchShortcut = event.key.toLowerCase() === 'k' && (event.metaKey || event.ctrlKey);

		if (isSearchShortcut) {
			event.preventDefault();
			openSearch();
		}

		if (event.key === 'Escape') {
			closeSearch();
		}
	});
</script>
