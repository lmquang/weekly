---
import Layout from '../layouts/Layout.astro';

const pageDescription = 'A Vietnamese translation of Ruan Yifeng’s open-source technology weekly.';
---

<Layout title="About" description={pageDescription} canonical={new URL('/about/', Astro.site).toString()}>
	<section class="mx-auto max-w-2xl text-center">
		<p class="text-[11px] font-bold uppercase tracking-[0.2em] text-gray-500 mb-4">About</p>
		<h1 class="text-4xl md:text-6xl font-medium tracking-tight text-black dark:text-white">Weekly in Vietnamese</h1>
		<p class="mt-6 text-lg md:text-xl leading-relaxed text-gray-600 dark:text-gray-400">{pageDescription}</p>
	</section>

	<section class="mx-auto mt-14 max-w-2xl divide-y divide-black/5 rounded-3xl border border-black/5 bg-black/[0.02] dark:divide-white/10 dark:border-white/10 dark:bg-white/[0.03]">
		<div class="p-6 sm:p-8">
			<p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500">Original</p>
			<p class="mt-3 leading-relaxed text-gray-600 dark:text-gray-400">
				Written by <a href="https://github.com/ruanyf" class="text-black dark:text-white underline decoration-black/20 dark:decoration-white/20 underline-offset-4 hover:decoration-black dark:hover:decoration-white transition-all">Ruan Yifeng</a>. Source: <a href="https://github.com/ruanyf/weekly" class="text-black dark:text-white underline decoration-black/20 dark:decoration-white/20 underline-offset-4 hover:decoration-black dark:hover:decoration-white transition-all">ruanyf/weekly</a>.
			</p>
		</div>

		<div class="p-6 sm:p-8">
			<p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500">Preface</p>
			<p class="mt-3 leading-relaxed text-gray-600 dark:text-gray-400">
				The magazine is open source, accepts contributions, and includes a “Who Is Hiring” service for programmer jobs. Collaboration: <a href="mailto:yifeng.ruan@gmail.com" class="text-black dark:text-white underline decoration-black/20 dark:decoration-white/20 underline-offset-4 hover:decoration-black dark:hover:decoration-white transition-all">yifeng.ruan@gmail.com</a>.
			</p>
		</div>

		<div class="p-6 sm:p-8">
			<p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500">Translation</p>
			<p class="mt-3 leading-relaxed text-gray-600 dark:text-gray-400">
				Translated by <a href="https://github.com/lmquang" class="text-black dark:text-white underline decoration-black/20 dark:decoration-white/20 underline-offset-4 hover:decoration-black dark:hover:decoration-white transition-all">Quang</a>. Contact: <a href="mailto:quanglm.ops@gmail.com" class="text-black dark:text-white underline decoration-black/20 dark:decoration-white/20 underline-offset-4 hover:decoration-black dark:hover:decoration-white transition-all">quanglm.ops@gmail.com</a>.
			</p>
		</div>
	</section>
</Layout>
