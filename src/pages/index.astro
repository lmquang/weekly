---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getIssueNumber, getIssueSummary, getIssueTitle } from '../lib/issues';

const pageDescription = 'Bản dịch tiếng Việt của các bản tin công nghệ hàng tuần về AI, lập trình, sản phẩm, Internet và xu hướng tương lai.';

const allIssues = await getCollection('issues');
// Sort by issue number descending
const sortedIssues = allIssues.sort((a, b) => {
    const numA = parseInt(getIssueNumber(a) || '0');
    const numB = parseInt(getIssueNumber(b) || '0');
    return numB - numA;
});

// Pre-render data for all sorted issues
const processedIssues = sortedIssues.map((issue) => {
	const date = issue.data.date;
    return {
        ...issue,
        displayTitle: getIssueTitle(issue),
		dateLabel: date instanceof Date ? date.toISOString().slice(0, 10) : date,
        summary: getIssueSummary(issue)
    };
});
---

<Layout title="Timeline: Our History in Tech" description={pageDescription}>
	<header class="mb-16 sm:mb-24 text-center">
		<h1 class="text-3xl sm:text-4xl md:text-5xl font-medium tracking-tight">Timeline: Our History in Tech</h1>
		<p class="mt-4 text-gray-500 max-w-lg mx-auto">Khám phá hành trình công nghệ qua các bản tin hàng tuần.</p>
	</header>
	
	<section class="relative">
		<!-- Constant vertical line background -->
		<div class="absolute left-[140px] sm:left-[113px] md:left-[177px] top-4 bottom-10 w-px bg-black/10 dark:bg-white/10 pointer-events-none"></div>
		
		<div class="flex flex-col" id="issue-timeline">
			{processedIssues.map((issue, index) => {
				const issueNumber = getIssueNumber(issue);
				return (
					<div class={`relative flex items-start gap-10 sm:gap-8 md:gap-16 pb-14 sm:pb-16 md:pb-20 last:pb-10 group timeline-item ${index >= 10 ? 'hidden' : ''}`} data-index={index}>
						{/* Left side: Issue Info */}
						<div class="w-30 sm:w-24 md:w-40 flex flex-col items-end text-right flex-shrink-0 pt-[7px]">
							<h3 class="text-sm sm:text-base md:text-lg font-medium text-black dark:text-white group-hover:text-link transition-colors leading-none">Issue #{issueNumber}</h3>
							<p class="text-[11px] md:text-xs text-gray-500 mt-2 uppercase tracking-wider">{issue.dateLabel ?? 'Weekly News'}</p>
						</div>

						{/* Center: Timeline Node */}
						<div class="absolute left-[130px] sm:left-[104px] md:left-[168px] top-0 bottom-0 flex flex-col items-center">
							<div class="w-5 h-5 rounded-full border-2 border-black dark:border-white bg-white dark:bg-black z-10 mt-[7px] ring-[6px] ring-white dark:ring-black group-hover:scale-110 transition-transform duration-300"></div>
						</div>

						{/* Right side: Content */}
						<div class="flex-1 pl-2 sm:pl-4 md:pl-0 min-w-0">
							<a href={`/issues/${issue.id}`} class="block">
								<h2 class="text-xl md:text-3xl font-medium tracking-tight mb-4 leading-tight text-black dark:text-white hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
									{issue.displayTitle}
								</h2>
								<p class="text-gray-600 dark:text-gray-500 leading-relaxed text-sm md:text-base max-w-xl mb-8">
									{issue.summary}
								</p>
								<span class="inline-block bg-black dark:bg-white text-white dark:text-black px-6 py-2.5 rounded-md font-semibold text-xs hover:opacity-80 dark:hover:bg-gray-200 transition-all duration-300 transform hover:-translate-y-0.5 active:translate-y-0 cursor-pointer">
									{index === 0 ? "Read Latest Issue" : "Read Issue"}
								</span>
							</a>
						</div>
					</div>
				);
			})}
		</div>
	</section>

	<div class="mt-12 flex justify-center">
		<button id="load-more" class="px-10 py-3 rounded-md bg-black dark:bg-white text-white dark:text-black font-bold text-[11px] uppercase tracking-widest hover:opacity-80 dark:hover:bg-gray-200 transition-all duration-300 min-w-[160px] flex items-center justify-center gap-3 active:scale-95 disabled:opacity-50 cursor-pointer">
			<span class="loader hidden w-3 h-3 border-2 border-white/30 dark:border-black/30 border-t-white dark:border-t-black rounded-full animate-spin"></span>
			<span class="btn-text">Load More</span>
		</button>
	</div>

	<script>
		let currentIndex = 10;
		const batchSize = 10;
		const loadMoreBtn = document.getElementById('load-more');
		const btnText = loadMoreBtn?.querySelector('.btn-text');
		const loader = loadMoreBtn?.querySelector('.loader');
		const items = document.querySelectorAll('.timeline-item');

		if (items.length <= currentIndex) {
			if (loadMoreBtn) loadMoreBtn.style.display = 'none';
		}

		loadMoreBtn?.addEventListener('click', () => {
			// Show loading state
			if (btnText) btnText.textContent = 'Loading...';
			if (loader) loader.classList.remove('hidden');
			loadMoreBtn.setAttribute('disabled', 'true');

			setTimeout(() => {
				const nextBatch = Array.from(items).slice(currentIndex, currentIndex + batchSize);
				nextBatch.forEach(item => {
					item.classList.remove('hidden');
					// Trigger animation
					item.style.opacity = '0';
					item.style.transform = 'translateY(20px)';
					requestAnimationFrame(() => {
						item.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
						item.style.opacity = '1';
						item.style.transform = 'translateY(0)';
					});
				});

				currentIndex += batchSize;

				// Reset button state
				if (btnText) btnText.textContent = 'Load More';
				if (loader) loader.classList.add('hidden');
				loadMoreBtn.removeAttribute('disabled');

				if (currentIndex >= items.length) {
					loadMoreBtn.style.display = 'none';
				}
			}, 800);
		});
	</script>
</Layout>
